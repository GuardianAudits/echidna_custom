+escapeByte :: Word8 -> String
+escapeByte w
+  | w == 0x22 = "\\\""
+  | w == 0x5c = "\\\\"
+  | w >= 0x20 && w <= 0x7e = [chr (fromIntegral w)]
+  | otherwise = "\\x" <> paddedShowHex 2 w
 
 -- |'paddedShowHex' displays a number in hexadecimal and pads the number
 -- with 0 so that it has a minimum length of @w@.
