+    upsertRvmLayoutRef :: (?conf :: Config, VMOps t, Typeable t) => FunctionSelector -> Addr -> RvmLayoutRef -> EVM t ()
+    upsertRvmLayoutRef sig target ref = do
+      refs <- fromMaybe mempty <$> use (#config % #rvmLayoutRefs % at target)
+      let nextRefs = filter (not . sameRvmLayoutDomain ref) refs <> [ref]
+      validateRvmLayoutRefs sig nextRefs $ do
+        modifying (#config % #rvmLayoutRefs) (Map.insert target nextRefs)
+        finishFrame (FrameReturned mempty)
+
+    isNamespaceRef :: RvmLayoutRef -> Bool
+    isNamespaceRef ref = case ref of
