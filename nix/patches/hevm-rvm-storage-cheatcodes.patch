+    sameRvmLayoutDomain :: RvmLayoutRef -> RvmLayoutRef -> Bool
+    sameRvmLayoutDomain new old = case (new, old) of
+      (RvmInline _, RvmInline _) -> True
+      (RvmInline _, RvmContract _) -> True
+      (RvmContract _, RvmInline _) -> True
+      (RvmContract _, RvmContract _) -> True
+      (RvmNamespace namespace _, RvmNamespace namespace' _) -> namespace == namespace'
+      (RvmNamespaceAt baseSlot _, RvmNamespaceAt baseSlot' _) -> baseSlot == baseSlot'
+      _ -> False
